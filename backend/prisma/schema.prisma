generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  STAFF
}

enum StaffRole {
  COLLEGE_ADMIN
  ADMISSIONS_OPERATOR
  CASHIER
  HR_OPERATOR
  ATTENDANCE_OPERATOR
  AUDITOR
}

enum StudentStatus {
  ACTIVE
  PASSED_OUT
  DROP_OUT
  SOFT_DELETED
}

enum PaymentType {
  FEE_COLLECTION
  MISC_CREDIT
  FINE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PROCESSED
  PAID
  REVERSED
}

enum AdmissionWorkflowStatus {
  SUBMITTED
  DOCUMENTS_VERIFIED
  FEE_VERIFIED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ExceptionStatus {
  NEW
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

enum ExceptionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExceptionModule {
  FINANCE
  PAYROLL
  HR
  ADMISSIONS
  PROCUREMENT
  STUDENT_OPERATIONS
  STUDENT_FEES
}

model Trust {
  id                 String   @id @default(cuid())
  name               String
  establishmentYear  Int
  registrationNumber String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  colleges           College[]
}

model College {
  id                     String      @id @default(cuid())
  trustId                String
  name                   String
  code                   String      @unique
  registrationYear       Int
  address                String
  university             String
  startingRollNumber     Int
  startingAdmissionNumber Int
  admissionNumberPrefix  String      @default("MTET/AD2026")
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  trust                  Trust       @relation(fields: [trustId], references: [id])
  courses                Course[]
  students               Student[]
  staffMembers           Staff[]
  customRoles            CustomRole[]
  expenses               Expense[]
  credits                Credit[]
  payments               Payment[]
  finePolicy             FinePolicy?
  vendors                Vendor[]
  budgets                Budget[]
  recurringExpenses      RecurringExpense[]
  pettyCashEntries       PettyCashEntry[]
}

model Course {
  id                String    @id @default(cuid())
  collegeId         String
  name              String
  courseCode        String
  courseFee         Decimal   @default(0) @db.Decimal(12, 2)
  requiredDocTypes  String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  college           College   @relation(fields: [collegeId], references: [id])
  sessions          Session[]
  subjects          Subject[]
  admissions        Admission[]

  @@unique([collegeId, courseCode])
}

model Session {
  id                     String    @id @default(cuid())
  courseId               String
  label                  String
  startYear              Int
  endYear                Int
  startingRollNumber     Int       @default(1)
  rollNumberPrefix       String    @default("MTET/R2026")
  admissionNumberPrefix  String?
  seatCount              Int       @default(0)
  sessionFee             Decimal   @default(0) @db.Decimal(12, 2)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  course                 Course    @relation(fields: [courseId], references: [id])
  admissions             Admission[]

  @@unique([courseId, label])
}

model Subject {
  id        String   @id @default(cuid())
  courseId  String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([courseId, code])
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  role           UserRole
  staffId        String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  staff          Staff?   @relation(fields: [staffId], references: [id])
  setupTokens    PasswordSetupToken[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Staff {
  id               String         @id @default(cuid())
  collegeId        String
  customRoleId     String?
  fullName         String
  email            String         @unique
  mobile           String
  role             StaffRole      @default(ATTENDANCE_OPERATOR)
  designation      String?
  staffType        String?
  employmentType   String?
  joiningDate      DateTime?

  // Extended personal profile (onboarding step 1 & 2)
  dob                   DateTime?
  gender                String?
  nationality           String?
  emergencyContact      String?
  currentAddress        String?
  currentCity           String?
  currentDistrict       String?
  currentState          String?
  currentPincode        String?
  currentCountry        String?
  permanentAddress      String?
  permanentCity         String?
  permanentDistrict     String?
  permanentState        String?
  permanentPincode      String?
  permanentCountry      String?

  // Employment details (onboarding step 3)
  department            String?
  functionalRole        String?
  subjectSpecialization String?
  qualification         String?
  experience            String?
  employmentStatus      String?

  isActive         Boolean        @default(true)
  invitedAt        DateTime?
  inviteAcceptedAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  college          College        @relation(fields: [collegeId], references: [id])
  customRole       CustomRole?    @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  user             User?
  salaryConfig     StaffSalaryConfig?
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  payrolls         Payroll[]

  @@index([customRoleId])
  @@index([collegeId, createdAt])
}

model CustomRole {
  id          String   @id @default(cuid())
  collegeId   String
  name        String
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  staff       Staff[]

  @@unique([collegeId, name])
  @@index([collegeId])
}

model Student {
  id                          String        @id @default(cuid())
  collegeId                   String
  admissionNumber             Int
  admissionCode               String?
  rollNumber                  Int?
  rollCode                    String?
  candidateName               String
  fatherName                  String
  motherName                  String
  dob                         DateTime
  gender                      String
  nationality                 String
  maritalStatus               String?
  bloodGroup                  String?
  background                  String?
  category                    String?
  religion                    String?
  identificationMark          String?
  mobile                      String
  fatherMobile                String
  email                       String
  permanentAddress            String
  mailingAddress              String
  previousQualificationJson   Json?
  discountAmount              Decimal       @default(0) @db.Decimal(12, 2)
  scholarshipAmount           Decimal       @default(0) @db.Decimal(12, 2)
  totalPayable                Decimal       @default(0) @db.Decimal(12, 2)
  universityEnrollmentNumber  String?
  universityRegistrationNumber String?
  status                      StudentStatus @default(ACTIVE)
  photoUrl                    String?
  isSoftDeleted               Boolean       @default(false)
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  college                     College       @relation(fields: [collegeId], references: [id])
  admissions                  Admission[]
  payments                    Payment[]
  feeReceipts                 FeeReceipt[]
  feeCollectionDrafts         FeeCollectionDraft[]
  feeCollectionExceptions     FeeCollectionException[]
  feeDemandCycles             FeeDemandCycle[]
  timeline                    StudentTimeline[]
  examResults                 ExamResult[]
  hostelAllocations           HostelAllocation[]
  libraryTransactions         LibraryTransaction[]
  transportAllocations        TransportAllocation[]

  @@unique([collegeId, admissionNumber])
  @@index([collegeId, createdAt])
  @@index([collegeId, status])
}

model Admission {
  id                  String   @id @default(cuid())
  studentId           String
  collegeId           String
  courseId            String
  sessionId           String
  declarationText     String
  declarationDate     DateTime @default(now())
  documentsVerifiedAt DateTime?
  feeVerifiedAt       DateTime?
  workflowStatus      AdmissionWorkflowStatus @default(SUBMITTED)
  workflowNotes       String?
  changeRequestItems  Json?
  workflowUpdatedAt   DateTime @default(now())
  createdAt           DateTime @default(now())
  student             Student  @relation(fields: [studentId], references: [id])
  course              Course   @relation(fields: [courseId], references: [id])
  session             Session  @relation(fields: [sessionId], references: [id])
  admissionDocuments  AdmissionDocument[]
}

model StudentTimeline {
  id         String   @id @default(cuid())
  studentId  String
  title      String
  details    String
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
}

model Payment {
  id            String      @id @default(cuid())
  collegeId     String
  studentId     String?
  amount        Decimal     @db.Decimal(12, 2)
  paymentType   PaymentType
  description   String
  receiptNumber String      @unique
  paymentMode   String?
  referenceNumber String?
  collectedBy   String?
  paidAt        DateTime    @default(now())
  createdAt     DateTime    @default(now())
  feeReceipt    FeeReceipt?
  reversal      PaymentReversal?
  college       College     @relation(fields: [collegeId], references: [id])
  student       Student?    @relation(fields: [studentId], references: [id])

  @@index([collegeId, createdAt])
  @@index([collegeId, studentId])
}

model PaymentReversal {
  id              String   @id @default(cuid())
  paymentId       String   @unique
  collegeId       String
  reason          String
  reversedBy      String?
  reversedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  payment         Payment  @relation(fields: [paymentId], references: [id])

  @@index([collegeId, reversedAt])
}

model FeeReceipt {
  id              String   @id @default(cuid())
  paymentId       String   @unique
  studentId       String
  receiptNumber   String   @unique
  cycleKey        String?
  cycleLabel      String?
  amount          Decimal  @db.Decimal(12, 2)
  lateFine        Decimal  @default(0) @db.Decimal(12, 2)
  totalReceived   Decimal  @db.Decimal(12, 2)
  paymentMode     String?
  referenceNumber String?
  collectedBy     String?
  collectedAt     DateTime
  snapshot        Json
  createdAt       DateTime @default(now())
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [studentId], references: [id])
}

model FeeCollectionDraft {
  id              String   @id @default(cuid())
  studentId       String
  collegeId       String
  cycleKey        String?
  amount          Decimal  @db.Decimal(12, 2)
  lateFine        Decimal  @default(0) @db.Decimal(12, 2)
  paymentMode     String?
  referenceNumber String?
  postingDate     DateTime?
  collectedBy     String?
  notes           String?
  status          String   @default("DRAFT")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

enum FeeDemandCycleStatus {
  OPEN
  PAID
  WAIVED
}

model FeeDemandCycle {
  id          String                @id @default(cuid())
  studentId   String
  collegeId   String
  cycleKey    String
  label       String
  dueDate     DateTime
  amount      Decimal               @db.Decimal(12, 2)
  paidAmount  Decimal               @default(0) @db.Decimal(12, 2)
  status      FeeDemandCycleStatus  @default(OPEN)
  createdAt   DateTime              @default(now())
  student     Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, cycleKey])
  @@index([studentId, status])
  @@index([collegeId, dueDate])
}

model FeeCollectionException {
  id                 String   @id @default(cuid())
  studentId          String
  collegeId          String
  cycleKey           String?
  requestedAmount    Decimal  @db.Decimal(12, 2)
  remainingBalance   Decimal  @db.Decimal(12, 2)
  reason             String
  status             String   @default("PENDING")
  requestedByUserId  String?
  reviewedByUserId   String?
  reviewNote         String?
  reviewedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status, createdAt])
}

model Credit {
  id          String   @id @default(cuid())
  collegeId   String
  amount      Decimal  @db.Decimal(12, 2)
  source      String
  notes       String?
  createdAt   DateTime @default(now())
  college     College  @relation(fields: [collegeId], references: [id])
}

model FinePolicy {
  id              String   @id @default(cuid())
  collegeId       String   @unique
  defaultFineAmount Decimal @default(0) @db.Decimal(12, 2)
  daysBrackets    Json     @default("[]") // Array<{daysAfterDue: number, fine: number}>
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  college         College  @relation(fields: [collegeId], references: [id])
}

model Expense {
  id               String    @id @default(cuid())
  collegeId        String
  amount           Decimal   @db.Decimal(12, 2)
  category         String
  subcategory      String?
  notes            String?
  description      String?
  spentOn          DateTime
  vendorId         String?
  vendorName       String?
  paymentSource    String?
  procurementRequestRef String?
  procurementOrderRef   String?
  goodsReceiptRef       String?
  sourceDocumentRef     String?
  approvalStatus   String    @default("PENDING")
  approvedByUserId String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionNote    String?
  attachmentUrl    String?
  attachmentPath   String?
  attachmentName   String?
  attachmentMime   String?
  attachmentSize   Int?
  createdAt        DateTime  @default(now())
  college          College   @relation(fields: [collegeId], references: [id])
  vendor           Vendor?   @relation(fields: [vendorId], references: [id])
  @@index([collegeId, category, spentOn])
  @@index([collegeId, createdAt])
}

model Vendor {
  id                String             @id @default(cuid())
  collegeId         String
  name              String
  gstNumber         String?
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  paymentTerms      String?
  bankName          String?
  bankAccount       String?
  ifscCode          String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  college           College            @relation(fields: [collegeId], references: [id])
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  vendorPayments    VendorPayment[]
}

model VendorPayment {
  id            String   @id @default(cuid())
  vendorId      String
  collegeId     String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMode   String   @default("BANK_TRANSFER")
  referenceNumber String?
  description   String
  expenseId     String?
  paidAt        DateTime @default(now())
  recordedBy    String?
  createdAt     DateTime @default(now())
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId, paidAt])
  @@index([collegeId, paidAt])
}

model Budget {
  id              String   @id @default(cuid())
  collegeId       String
  category        String
  subcategory     String?
  allocatedAmount Decimal  @db.Decimal(12, 2)
  financialYear   String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  college         College  @relation(fields: [collegeId], references: [id])

  @@unique([collegeId, category, financialYear])
}

model RecurringExpense {
  id          String   @id @default(cuid())
  collegeId   String
  title       String
  category    String
  subcategory String?
  amount      Decimal  @db.Decimal(12, 2)
  frequency   String
  nextDueDate DateTime
  vendorId    String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  college     College  @relation(fields: [collegeId], references: [id])
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
}

model PettyCashEntry {
  id             String   @id @default(cuid())
  collegeId      String
  entryType      String
  amount         Decimal  @db.Decimal(12, 2)
  description    String
  reference      String?
  runningBalance Decimal  @db.Decimal(12, 2)
  recordedBy     String?
  createdAt      DateTime @default(now())
  college        College  @relation(fields: [collegeId], references: [id])
}

model Attendance {
  id         String   @id @default(cuid())
  staffId    String
  date       DateTime
  status     String
  remarks    String?
  createdAt  DateTime @default(now())
  staff      Staff    @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

model LeaveRequest {
  id         String      @id @default(cuid())
  staffId    String
  fromDate   DateTime
  toDate     DateTime
  reason     String
  leaveType  String?
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  staff      Staff       @relation(fields: [staffId], references: [id])
}

model LeaveBalance {
  id        String   @id @default(cuid())
  staffId   String
  leaveType String
  totalDays Int      @default(0)
  usedDays  Int      @default(0)
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, leaveType, year])
  @@index([staffId, year])
}

model Payroll {
  id               String        @id @default(cuid())
  staffId          String
  amount           Decimal       @db.Decimal(12, 2)
  grossAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalDeductions  Decimal       @default(0) @db.Decimal(12, 2)
  netAmount        Decimal       @default(0) @db.Decimal(12, 2)
  month            Int
  year             Int
  status           PayrollStatus @default(PROCESSED)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  staff            Staff         @relation(fields: [staffId], references: [id])
  deductions       PayrollDeduction[]

  @@index([staffId, year, month])
}

enum PayrollDeductionType {
  PF
  TDS
  ADVANCE
  BONUS
  OTHER
}

model PayrollDeduction {
  id        String               @id @default(cuid())
  payrollId String
  type      PayrollDeductionType
  label     String
  amount    Decimal              @db.Decimal(12, 2)
  createdAt DateTime             @default(now())
  payroll   Payroll              @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
}


model StaffSalaryConfig {
  id                String   @id @default(cuid())
  staffId           String   @unique
  basicSalary       Decimal  @default(0) @db.Decimal(12, 2)
  hra               Decimal  @default(0) @db.Decimal(12, 2)
  da                Decimal  @default(0) @db.Decimal(12, 2)
  otherAllowances   Decimal  @default(0) @db.Decimal(12, 2)
  bankAccountNumber String?
  bankName          String?
  ifscCode          String?
  pan               String?
  pfUan             String?
  paymentMode       String   @default("BANK_TRANSFER")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  staff             Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model StaffOnboardingDraft {
  id              String   @id @default(cuid())
  createdByUserId String
  collegeId       String
  formDataJson    Json
  step            Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdByUserId, collegeId])
}

model SequenceCounter {
  id        String   @id @default(cuid())
  scope     String
  key       String
  value     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, key])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String   @unique
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

model AppSetting {
  id                         String   @id @default("default")
  timezone                   String   @default("Asia/Kolkata")
  currency                   String   @default("INR")
  dateFormat                 String   @default("DD-MM-YYYY")
  authStandard               String   @default("JWT with role based access control")
  staffDefaultPasswordPolicy String   @default("No default passwords. Staff are onboarded using one-time invite links with password setup.")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ExceptionCase {
  id               String            @id @default(cuid())
  collegeId        String
  module           ExceptionModule
  category         String
  severity         ExceptionSeverity @default(MEDIUM)
  title            String
  description      String
  sourceEntityType String?
  sourceEntityId   String?
  sourceOperation  String?
  dedupeKey        String?
  idempotencyKey   String?           @unique
  status           ExceptionStatus   @default(NEW)
  isRetryable      Boolean           @default(false)
  retryCount       Int               @default(0)
  maxRetries       Int               @default(3)
  assignmentRule   String?
  assigneeStaffId  String?
  assigneeUserId   String?
  assignedAt       DateTime?
  triagedAt        DateTime?
  inProgressAt     DateTime?
  resolvedAt       DateTime?
  closedAt         DateTime?
  reopenedAt       DateTime?
  slaDueAt         DateTime?
  escalatedAt      DateTime?
  resolutionSummary String?
  rootCause        String?
  metadata         Json?
  createdByUserId  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  history          ExceptionHistory[]

  @@index([collegeId, status, createdAt])
  @@index([module, status, createdAt])
  @@index([severity, status, createdAt])
  @@index([dedupeKey, status])
  @@index([slaDueAt, status])
}

model Document {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  collegeId     String
  fileName      String
  storagePath   String
  mimeType      String   @default("application/octet-stream")
  sizeBytes     Int?
  uploadedBy    String?
  createdAt     DateTime @default(now())
  admissionDocs AdmissionDocument[]

  @@index([entityType, entityId])
  @@index([collegeId, createdAt])
}

model AdmissionDocument {
  id          String    @id @default(cuid())
  admissionId String
  documentId  String
  docType     String
  createdAt   DateTime  @default(now())
  admission   Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([admissionId, docType])
}

model NotificationLog {
  id             String   @id @default(cuid())
  collegeId      String?
  recipientId    String?
  recipientEmail String?
  channel        String   @default("EMAIL")
  subject        String
  body           String
  sentAt         DateTime?
  readAt         DateTime?
  isRead         Boolean  @default(false)
  status         String   @default("PENDING")
  error          String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, channel, isRead, createdAt])
  @@index([status, createdAt])
}

model ExceptionHistory {
  id              String          @id @default(cuid())
  exceptionCaseId String
  eventType       String
  fromStatus      ExceptionStatus?
  toStatus        ExceptionStatus?
  note            String?
  actorUserId     String?
  actorStaffId    String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  exceptionCase   ExceptionCase   @relation(fields: [exceptionCaseId], references: [id], onDelete: Cascade)

  @@index([exceptionCaseId, createdAt])
  @@index([eventType, createdAt])
}

// ─── Phase 3: Exam Module ────────────────────────────────────────────────────

enum ExamType {
  INTERNAL
  EXTERNAL
  PRACTICAL
  VIVA
}

model ExamSchedule {
  id           String     @id @default(cuid())
  collegeId    String
  courseId     String
  sessionId    String
  subjectId    String?
  title        String
  examType     ExamType   @default(INTERNAL)
  examDate     DateTime
  startTime    String?
  endTime      String?
  venue        String?
  maxMarks     Decimal    @default(100) @db.Decimal(6, 2)
  passingMarks Decimal    @default(40)  @db.Decimal(6, 2)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  results      ExamResult[]

  @@index([collegeId, examDate])
  @@index([courseId, sessionId, examDate])
}

model ExamResult {
  id            String       @id @default(cuid())
  scheduleId    String
  studentId     String
  collegeId     String
  marksObtained Decimal?     @db.Decimal(6, 2)
  isPassed      Boolean?
  grade         String?
  remarks       String?
  isAbsent      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  schedule      ExamSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, studentId])
  @@index([studentId, createdAt])
  @@index([collegeId, createdAt])
}

// ─── Phase 3: Hostel Module ──────────────────────────────────────────────────

enum HostelRoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum HostelAllocationStatus {
  ACTIVE
  VACATED
  RESERVED
}

model HostelBlock {
  id        String       @id @default(cuid())
  collegeId String
  name      String
  gender    String       @default("ANY")
  floors    Int          @default(1)
  notes     String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  rooms     HostelRoom[]

  @@unique([collegeId, name])
  @@index([collegeId])
}

model HostelRoom {
  id          String             @id @default(cuid())
  blockId     String
  collegeId   String
  roomNumber  String
  floor       Int                @default(1)
  roomType    HostelRoomType     @default(SINGLE)
  capacity    Int                @default(1)
  feePerTerm  Decimal            @default(0) @db.Decimal(12, 2)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  block       HostelBlock        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  allocations HostelAllocation[]

  @@unique([blockId, roomNumber])
  @@index([collegeId])
}

model HostelAllocation {
  id        String                 @id @default(cuid())
  roomId    String
  studentId String
  collegeId String
  fromDate  DateTime
  toDate    DateTime?
  status    HostelAllocationStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  room      HostelRoom             @relation(fields: [roomId], references: [id])
  student   Student                @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([roomId, status])
  @@index([collegeId, status])
}

// ─── Phase 3: Library Module ─────────────────────────────────────────────────

enum LibraryTransactionStatus {
  ISSUED
  RETURNED
  OVERDUE
  LOST
}

model LibraryBook {
  id              String               @id @default(cuid())
  collegeId       String
  title           String
  author          String
  isbn            String?
  publisher       String?
  edition         String?
  category        String?
  totalCopies     Int                  @default(1)
  availableCopies Int                  @default(1)
  shelfLocation   String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  transactions    LibraryTransaction[]

  @@index([collegeId, category])
  @@index([collegeId, isActive])
}

model LibraryTransaction {
  id         String                   @id @default(cuid())
  bookId     String
  studentId  String
  collegeId  String
  issueDate  DateTime                 @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     LibraryTransactionStatus @default(ISSUED)
  fine       Decimal                  @default(0) @db.Decimal(10, 2)
  finePaid   Boolean                  @default(false)
  issuedBy   String?
  returnedTo String?
  notes      String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  book       LibraryBook              @relation(fields: [bookId], references: [id])
  student    Student                  @relation(fields: [studentId], references: [id])

  @@index([bookId, status])
  @@index([studentId, status])
  @@index([collegeId, status])
  @@index([dueDate, status])
}

// ─── Phase 3: Transport Module ───────────────────────────────────────────────

enum TransportAllocationStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

model TransportRoute {
  id            String                @id @default(cuid())
  collegeId     String
  routeCode     String
  routeName     String
  stops         String[]              @default([])
  vehicleNumber String?
  driverName    String?
  driverPhone   String?
  conductorName String?
  departureTime String?
  returnTime    String?
  feePerTerm    Decimal               @default(0) @db.Decimal(12, 2)
  isActive      Boolean               @default(true)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  allocations   TransportAllocation[]

  @@unique([collegeId, routeCode])
  @@index([collegeId, isActive])
}

model TransportAllocation {
  id         String                    @id @default(cuid())
  routeId    String
  studentId  String
  collegeId  String
  fromDate   DateTime
  toDate     DateTime?
  status     TransportAllocationStatus @default(ACTIVE)
  pickupStop String?
  notes      String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  route      TransportRoute            @relation(fields: [routeId], references: [id])
  student    Student                   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([routeId, status])
  @@index([collegeId, status])
}
