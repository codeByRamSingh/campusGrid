# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/campusgrid?schema=public
POSTGRES_DB=campusgrid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ─── Application ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET
PORT=4000

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:80,http://localhost
FRONTEND_URL=http://localhost

# ─── Frontend API URL ────────────────────────────────────────────────────────
# Override for non-localhost deployments. This is baked into the frontend bundle at build time.
# For local dev: use http://localhost:4000/api
# For production: use your actual backend URL (e.g., https://api.example.com/api)
VITE_API_URL=http://localhost:4000/api

# ─── SMTP (optional — enables invite emails, receipt emails, reminders) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@campusgrid.local
